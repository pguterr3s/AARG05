set / system name host-name {{ host }}
set / interface lo0 admin-state enable
set / interface lo0 subinterface 0 admin-state enable
set / interface lo0 subinterface 0 ipv4 admin-state enable
set / interface lo0 subinterface 0 ipv4 address {{ loopback }}
{% for intf, data in interfaces.items() %}
set / interface {{ intf }} admin-state enable
set / interface {{ intf }} subinterface 0 admin-state enable
set / interface {{ intf }} subinterface 0 ipv4 admin-state enable
set / interface {{ intf }} subinterface 0 ipv4 address {{ data.ip }}/{{ data.mask }}
{% endfor %}
set / network-instance default type default
set / network-instance default admin-state enable
set / network-instance default interface lo0.0
{% for intf in interfaces.keys() %}
set / network-instance default interface {{ intf }}.0
{% endfor %}
set / network-instance default protocols ospf instance {{ process }} admin-state enable
set / network-instance default protocols ospf instance {{ process }} version ospf-v2
set / network-instance default protocols ospf instance {{ process }} router-id {{ router_id }}
set / network-instance default protocols ospf instance {{ process }} area 0.0.0.0
set / network-instance default protocols ospf instance {{ process }} area 0.0.0.0 interface lo0.0 interface-type point-to-point
{% for intf, data in interfaces.items() %}
set / network-instance default protocols ospf instance {{ process }} area {{ data.ospf_area }} interface {{ intf }}.0 interface-type point-to-point
{% endfor %}
